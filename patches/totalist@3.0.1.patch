diff --git a/sync/index.mjs b/sync/index.mjs
index e751c3f99389463dc5226869b1d1997a5149cbdb..a31b187139647ac2a2e1c6f6932a7da84cd4d397 100644
--- a/sync/index.mjs
+++ b/sync/index.mjs
@@ -1,13 +1,36 @@
 import { join, resolve } from 'path';
 import { readdirSync, statSync } from 'fs';
 
+// [Open Knowledge patch] — tolerate un-stat-able entries (broken symlinks,
+// permission-denied) instead of crashing the whole walk with ENOENT/EACCES.
+// Rationale: upstream totalist (v3.0.1) does a synchronous statSync on every
+// entry and propagates errors. Consumers like sirv use it at server-startup
+// time to enumerate assets for etag/cache-control; a single broken symlink
+// anywhere under the served tree kills the server before it binds — with no
+// diagnostic beyond the stat error. In our monorepo, `tmp/ship/` routinely
+// contains relative symlinks from `/review-local` plugin bundles that
+// resolve to different layouts than the monorepo checkout. Those links are
+// harmless (gitignored scratch), but upstream totalist makes them fatal.
+// Upstream PR candidate; meanwhile this patch makes the walker skip.
+
 export function totalist(dir, callback, pre='') {
 	dir = resolve('.', dir);
-	let arr = readdirSync(dir);
+	let arr;
+	try {
+		arr = readdirSync(dir);
+	} catch (e) {
+		if (e && (e.code === 'ENOENT' || e.code === 'EACCES' || e.code === 'ENOTDIR')) return;
+		throw e;
+	}
 	let i=0, abs, stats;
 	for (; i < arr.length; i++) {
 		abs = join(dir, arr[i]);
-		stats = statSync(abs);
+		try {
+			stats = statSync(abs);
+		} catch (e) {
+			if (e && (e.code === 'ENOENT' || e.code === 'EACCES')) continue;
+			throw e;
+		}
 		stats.isDirectory()
 			? totalist(abs, callback, join(pre, arr[i]))
 			: callback(join(pre, arr[i]), abs, stats);
