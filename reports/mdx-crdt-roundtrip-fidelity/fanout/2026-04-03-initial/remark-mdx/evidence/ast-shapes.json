{
  "description": "Canonical AST shapes for all MDX node types, extracted from source code and test suites",
  "generated_from": [
    "mdast-util-mdx-jsx/index.d.ts",
    "mdast-util-mdx-expression/index.d.ts",
    "mdast-util-mdxjs-esm/index.d.ts",
    "mdx/packages/remark-mdx/test/index.js",
    "mdast-util-mdx/test.js"
  ],
  "node_types": {
    "mdxJsxFlowElement": {
      "description": "Block-level JSX element. Created when JSX tag starts at beginning of a line (flow context). Children are BlockContent | DefinitionContent.",
      "example_input": "<Callout type=\"warning\">\n  Important **note**.\n</Callout>",
      "ast_shape": {
        "type": "mdxJsxFlowElement",
        "name": "Callout",
        "attributes": [
          {
            "type": "mdxJsxAttribute",
            "name": "type",
            "value": "warning"
          }
        ],
        "children": [
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "value": "Important " },
              { "type": "strong", "children": [{ "type": "text", "value": "note" }] },
              { "type": "text", "value": "." }
            ]
          }
        ]
      },
      "notes": [
        "name is null for fragments (<></>)",
        "children are full block-level MDAST nodes (paragraph, heading, code, etc.)",
        "Markdown inside children IS parsed as markdown",
        "Self-closing elements have empty children array",
        "Extends MdastParent"
      ]
    },
    "mdxJsxTextElement": {
      "description": "Inline JSX element. Created when JSX tag appears within text/phrasing content. Children are PhrasingContent only.",
      "example_input": "Alpha <b>*bravo*</b> charlie.",
      "ast_shape": {
        "type": "mdxJsxTextElement",
        "name": "b",
        "attributes": [],
        "children": [
          { "type": "emphasis", "children": [{ "type": "text", "value": "bravo" }] }
        ]
      },
      "notes": [
        "Children are phrasing content only (text, emphasis, strong, link, etc.)",
        "Cannot contain block content (headings, paragraphs, code blocks)",
        "text JSX cannot span blank lines (parser throws 'end-tag-mismatch')",
        "Extends MdastParent"
      ]
    },
    "mdxJsxAttribute": {
      "description": "Named JSX attribute. value is string for literals, MdxJsxAttributeValueExpression for expressions, null/undefined for boolean.",
      "examples": {
        "string_value": {
          "input": "type=\"warning\"",
          "ast": { "type": "mdxJsxAttribute", "name": "type", "value": "warning" }
        },
        "expression_value": {
          "input": "data={chartData}",
          "ast": {
            "type": "mdxJsxAttribute",
            "name": "data",
            "value": {
              "type": "mdxJsxAttributeValueExpression",
              "value": "chartData",
              "data": { "estree": "<<ESTree Program>>" }
            }
          }
        },
        "boolean_value": {
          "input": "collapsed",
          "ast": { "type": "mdxJsxAttribute", "name": "collapsed", "value": null }
        }
      }
    },
    "mdxJsxExpressionAttribute": {
      "description": "Spread or expression attribute like {...props}",
      "example_input": "{...properties}",
      "ast_shape": {
        "type": "mdxJsxExpressionAttribute",
        "value": "...properties",
        "data": { "estree": "<<ESTree Program>>" }
      }
    },
    "mdxJsxAttributeValueExpression": {
      "description": "Expression as attribute value (the {expr} in name={expr})",
      "ast_shape": {
        "type": "mdxJsxAttributeValueExpression",
        "value": "chartData",
        "data": { "estree": "<<ESTree Program>>" }
      },
      "notes": [
        "value is the raw string between the braces",
        "data.estree is the parsed ESTree AST (when acorn is configured)"
      ]
    },
    "mdxFlowExpression": {
      "description": "Block-level expression like {variable} on its own line",
      "example_input": "{1 + 1}",
      "ast_shape": {
        "type": "mdxFlowExpression",
        "value": "1 + 1",
        "data": { "estree": "<<ESTree Program>>" }
      },
      "notes": [
        "Extends MdastLiteral (has value, not children)",
        "value is the raw string between braces (not including braces)"
      ]
    },
    "mdxTextExpression": {
      "description": "Inline expression like {variable} within text",
      "ast_shape": {
        "type": "mdxTextExpression",
        "value": "1 + 1",
        "data": { "estree": "<<ESTree Program>>" }
      }
    },
    "mdxjsEsm": {
      "description": "Import/export statement at file level",
      "example_input": "import { Chart } from './Chart'",
      "ast_shape": {
        "type": "mdxjsEsm",
        "value": "import { Chart } from './Chart'",
        "data": { "estree": "<<ESTree Program with ImportDeclaration>>" }
      },
      "notes": [
        "Extends MdastLiteral",
        "Registered in FrontmatterContentMap (treated as frontmatter-level)",
        "value preserves the original string exactly",
        "Multiple imports separated by blank lines become separate nodes"
      ]
    }
  }
}
