#!/usr/bin/env bash
# claude-sandbox one-liner installer.
#
#   curl -fsSL https://raw.githubusercontent.com/inkeep/claude-sandbox/main/install.sh | bash
#
# Non-interactive:
#   curl -fsSL https://raw.githubusercontent.com/inkeep/claude-sandbox/main/install.sh | bash -s -- -y
#
# Skip container image builds (useful on first run, build on demand later):
#   curl -fsSL https://raw.githubusercontent.com/inkeep/claude-sandbox/main/install.sh | bash -s -- --skip-build
#
# Re-running is safe — it's just a wrapper around `git pull` + `bootstrap.sh`.

set -euo pipefail

REPO_URL="${CC_SANDBOX_REPO:-https://github.com/inkeep/claude-sandbox.git}"
INSTALL_DIR="${CC_SANDBOX_HOME:-$HOME/.claude-sandbox}"

say() { printf '\033[1;34m[install]\033[0m %s\n' "$*" >&2; }

if [[ -d "$INSTALL_DIR/.git" ]]; then
  say "Updating existing install at $INSTALL_DIR..."
  git -C "$INSTALL_DIR" fetch --quiet origin main
  if ! git -C "$INSTALL_DIR" merge --ff-only --quiet origin/main; then
    say "Fast-forward failed — your install has local changes."
    say "Rename/delete $INSTALL_DIR and re-run, or resolve manually with 'git -C $INSTALL_DIR status'."
    exit 1
  fi
else
  say "Cloning $REPO_URL → $INSTALL_DIR..."
  git clone --quiet "$REPO_URL" "$INSTALL_DIR"
fi

say "Running bootstrap..."
exec "$INSTALL_DIR/bootstrap.sh" "$@"
