#!/usr/bin/env zsh
# Sandbox-recipes tier launcher. Invoked via symlinks named ccs/ccu/ccb/ccbu/ccm/ccmu
# living in ~/.local/bin (or wherever bootstrap --install-path placed them).
#
# Dispatch based on $0: the symlink's basename tells us which tier to launch.
#
# Registry: reads ~/.ok-projects.sh if present to pick up user-added repos.
# That file is a shared source of truth between PATH scripts and shell functions.
#
# Usage:  <alias-name> [-p <project>] [claude args...]

set -euo pipefail

# SANDBOX_RECIPES is baked in by bootstrap.sh at install time (sed substitution).
# Uninstalled copy has a relative placeholder; installed copy has an absolute path.
# Detect via leading '/' so the detection line isn't itself rewritten by sed.
SANDBOX_RECIPES="@@SANDBOX_RECIPES@@"
if [[ "$SANDBOX_RECIPES" != /* ]]; then
  # Uninstalled: resolve from script location (bin/ is a child of sandbox-recipes/)
  local self_dir
  self_dir="${0:A:h}"
  SANDBOX_RECIPES="${self_dir:h}"
fi

# ── Project registry ─────────────────────────────────────────────────────
# Single source of truth: ~/.ok-projects.sh (created by bootstrap.sh).
# Shared with the zshrc shell functions so they both see the same keys.
typeset -gA _OK_PROJECTS
if [[ -f "$HOME/.ok-projects.sh" ]]; then
  source "$HOME/.ok-projects.sh"
fi

# ── -p <project> extraction ──────────────────────────────────────────────
_resolve_project() {
  local key="${1:-}"
  [[ -z "$key" ]] && return 1
  [[ -n "${_OK_PROJECTS[$key]:-}" ]] || return 1
  printf '%s' "${_OK_PROJECTS[$key]}"
}

# Capture the symlink basename *before* entering any function, because inside
# a zsh function $0 resolves to the function name, not the script invocation.
INVOKED_AS="${0:t}"

# ── Help output ──────────────────────────────────────────────────────────
# Launcher intercepts --help/-h and --about. Pass-through to claude via --.
print_short_help() {
  local name="$INVOKED_AS"
  local tier_desc=""
  case "$name" in
    ccs)  tier_desc="Tier 0 — Seatbelt sandbox (kernel-level, no container)." ;;
    ccu)  tier_desc="Tier 0 — Seatbelt + unattended (--dangerously-skip-permissions)." ;;
    ccb)  tier_desc="Tier 1 — Apple Container microVM (real kernel boundary)." ;;
    ccbu) tier_desc="Tier 1 — Apple Container microVM + unattended." ;;
    ccm)  tier_desc="Tier 1 Matryoshka — microVM + bubblewrap + Anthropic proxy." ;;
    ccmu) tier_desc="Tier 1 Matryoshka + unattended (strongest isolation in this set)." ;;
    *)    tier_desc="sandbox-recipes launcher" ;;
  esac

  cat >&2 <<EOF
$name — $tier_desc

Usage:
  $name [-p <project>] [claude args...]
  $name -- [args to claude, bypasses launcher flags]
  $name --about       # show tier comparison chart
  $name --help        # this message

Examples:
  $name                       # launch in current directory
  $name -p ok                 # cd to project 'ok', then launch
  $name -p ok -r abc123       # + pass claude's -r (resume session)
  $name -- --help             # show claude's own help (bypasses launcher)

Project registry: ~/.ok-projects.sh   (list via 'ccp-list' in your shell)

Claude's -p (print mode) is shadowed by our -p. Use --print instead.
EOF
}

print_about() {
  cat >&2 <<'EOF'
Open Knowledge sandbox-recipes — tier comparison

  Command     Tier                                Permissions     Use for
  ─────────   ─────────────────────────────────   ─────────────   ──────────────────────────────
  cc          (your existing; no sandbox)         bypass prompts  I-know-what-I'm-doing escape
  ccs         Tier 0 — Seatbelt (kernel)          interactive     daily work on trusted code
  ccu         Tier 0 — Seatbelt                   unattended      AFK runs on trusted code
  ccb         Tier 1 — Apple Container microVM    interactive     OSS PR / partner code review
  ccbu        Tier 1 — Apple Container microVM    unattended      unattended untrusted-code
  ccm         Tier 1 — Matryoshka (VM+bubblewrap) interactive     strongest; semi-trusted review
  ccmu        Tier 1 — Matryoshka                 unattended      strongest + AFK

  Shape:      <cmd> [-p <project>] [claude args]
  Project:    -p <key>    (see ~/.ok-projects.sh or run 'ccp-list')
  Helpers:    ccp <key>   (cd only)     ccp-list (show registry)     cc-setup (re-run bootstrap)

  Suffixes:
    cc + s   → Seatbelt sandbox
         u   → unattended (Tier 0 shortcut; asymmetric with ccb/ccm below)
         b   → Boxed (Apple Container microVM)
         m   → Matryoshka (microVM + bubblewrap + Anthropic proxy)
         p   → Project helper (cd-only — shell function only, not PATH)
    + u appended to b/m → unattended variant (ccbu, ccmu)

  Full docs: sandbox-recipes/ALIASES.md (next to this launcher)
EOF
}

# Intercept help flags BEFORE -p parsing so they work regardless of args.
for arg in "$@"; do
  case "$arg" in
    --) break ;;   # stop scanning: everything after -- is pass-through
    --help|-h) print_short_help; exit 0 ;;
    --about|--tiers) print_about; exit 0 ;;
  esac
done

# ── -p <project> extraction ──────────────────────────────────────────────
typeset -a remaining=()
proj=""
while (( $# > 0 )); do
  case "$1" in
    --)
      # Everything after -- goes through untouched (including claude's -h/-p)
      shift
      remaining+=("$@")
      break
      ;;
    -p)
      if [[ -z "${2:-}" ]] || [[ "${2:-}" == -* ]]; then
        echo "error: -p requires a project shortcut (use 'ccp-list' in your shell)" >&2
        exit 64
      fi
      if [[ -n "$proj" ]]; then
        echo "error: -p specified more than once" >&2
        exit 64
      fi
      proj="$2"
      shift 2
      ;;
    *)
      remaining+=("$1")
      shift
      ;;
  esac
done

if [[ -n "$proj" ]]; then
  if ! dir="$(_resolve_project "$proj")"; then
    echo "error: unknown project shortcut: '$proj'" >&2
    if (( ${#_OK_PROJECTS[@]} == 0 )); then
      echo "       project registry is empty." >&2
      echo "       edit ~/.ok-projects.sh to add entries, or re-run bootstrap:" >&2
      echo "         $SANDBOX_RECIPES/bootstrap.sh --install-path" >&2
    else
      echo "       known: ${(k)_OK_PROJECTS}" >&2
      echo "       edit ~/.ok-projects.sh to add more." >&2
    fi
    exit 1
  fi
  cd "$dir" || exit 1
fi

# ── Dispatch ─────────────────────────────────────────────────────────────
case "$INVOKED_AS" in
  ccs)
    exec claude --effort max "${remaining[@]}"
    ;;
  ccu)
    exec claude --dangerously-skip-permissions --effort max "${remaining[@]}"
    ;;
  ccb)
    exec "$SANDBOX_RECIPES/tier1-apple-container/ok-sandbox.sh" "${remaining[@]}"
    ;;
  ccbu)
    exec "$SANDBOX_RECIPES/tier1-apple-container/ok-sandbox.sh" --unattended "${remaining[@]}"
    ;;
  ccm)
    exec "$SANDBOX_RECIPES/tier1-matryoshka/ok-sandbox.sh" "${remaining[@]}"
    ;;
  ccmu)
    exec "$SANDBOX_RECIPES/tier1-matryoshka/ok-sandbox.sh" --unattended "${remaining[@]}"
    ;;
  ok-launcher|ok-sandbox)
    # Direct invocation without symlink — print usage.
    cat >&2 <<EOF
ok-launcher: launched directly, expected a symlink invocation.

Install symlinks with:
  $SANDBOX_RECIPES/bootstrap.sh --install-path

Or invoke by creating symlinks yourself:
  ln -sf "$0" ~/.local/bin/ccs
  ln -sf "$0" ~/.local/bin/ccb
  (and so on for ccu, ccbu, ccm, ccmu)
EOF
    exit 64
    ;;
  *)
    echo "ok-launcher: invoked with unknown name: $INVOKED_AS" >&2
    echo "       expected one of: ccs, ccu, ccb, ccbu, ccm, ccmu" >&2
    exit 64
    ;;
esac
