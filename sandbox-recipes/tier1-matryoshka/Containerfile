# Matryoshka: extends the Tier 1 base with @anthropic-ai/sandbox-runtime preinstalled
# and a pre-baked ~/.claude/settings.json enabling the built-in sandbox.
#
# Built separately from tier1-apple-container because this image has different
# defaults — built-in /sandbox is ON, network allowlist is stricter (Anthropic's
# proxy does the enforcement, so we can trust it more than guest-side iptables).

FROM debian:bookworm-slim

ARG NODE_VERSION=22
ARG CLAUDE_USER=claude
ARG CLAUDE_UID=1000

# Same base deps as tier1-apple-container — plus we will need bubblewrap + socat
# functional for the inner sandbox to work, and ripgrep for @anthropic-ai/sandbox-runtime.
RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      jq \
      sudo \
      bubblewrap \
      socat \
      dnsutils \
      ripgrep \
      tini \
 && rm -rf /var/lib/apt/lists/*

# Apple Container's guest kernel rejects bubblewrap's Debian default caps-based
# config with: "bwrap: Unexpected capabilities but not setuid, old file caps config?"
# Discovered during smoke-testing the matryoshka pattern on container v0.11.
# Fix: switch bwrap to setuid-root by stripping file caps and setting the suid bit.
# This is how Fedora/Arch ship bubblewrap by default and works across all kernels.
RUN setcap -r /usr/bin/bwrap 2>/dev/null || true \
 && chmod u+s /usr/bin/bwrap

RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/*

# Install BOTH Claude Code and the sandbox runtime (for inspection / nested use)
RUN npm install -g @anthropic-ai/claude-code @anthropic-ai/sandbox-runtime \
 && npm cache clean --force

# Non-root user
RUN useradd -m -s /bin/bash -u "${CLAUDE_UID}" "${CLAUDE_USER}"

# Pre-bake Claude Code settings so /sandbox is enabled on launch
RUN mkdir -p "/home/${CLAUDE_USER}/.claude"
COPY settings.json "/home/${CLAUDE_USER}/.claude/settings.json"
COPY verify-matryoshka.sh /home/${CLAUDE_USER}/verify-matryoshka.sh
RUN chown -R "${CLAUDE_USER}:${CLAUDE_USER}" "/home/${CLAUDE_USER}/.claude" \
 && chmod +x /home/${CLAUDE_USER}/verify-matryoshka.sh

WORKDIR /workspace
USER ${CLAUDE_USER}

# No entrypoint script — we don't need the firewall init because Anthropic's
# sandbox proxy handles network enforcement. Direct exec.
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["claude"]
