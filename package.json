{
  "name": "open-knowledge",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11"
  },
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check packages docs package.json turbo.json tsconfig.json biome.jsonc --error-on-warnings",
    "format": "bun run lint --write --unsafe",
    "check": "bun run lint && turbo run typecheck test test:integration test:conversion test:fidelity",
    "check:full:parallel": "bun run lint && turbo run typecheck test test:integration test:conversion test:stress:server-authoritative test:fuzz:bridge test:e2e --concurrency=100% --output-logs=errors-only",
    "tier1": "bun run check",
    "tier2": "bun run tier1 && turbo run test:stress:server-authoritative test:fuzz:bridge test:perf:regression:unit test:health:unit test:health test:e2e",
    "tier3": "STRESS_FIDELITY=1 STRESS_FUZZ_NIGHTLY=1 bun run tier2",
    "dev": "bun run dev:mcp && cd packages/app && bun run dev",
    "dev:mcp": "bun packages/cli/src/dev-mcp-setup.ts",
    "prepare": "husky && chmod +x .husky/pre-commit .husky/pre-push 2>/dev/null || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --error-on-warnings"
    ],
    "docs/**/*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --error-on-warnings"
    ],
    "{package.json,turbo.json,tsconfig.json,biome.jsonc}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --error-on-warnings"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.29.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "bun-types": "^1.3.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-diff3": "^3.2.0",
    "turbo": "^2.7.0"
  },
  "overrides": {
    "@codemirror/state": "$@codemirror/state",
    "@codemirror/view": "$@codemirror/view"
  },
  "patchedDependencies": {
    "@handlewithcare/remark-prosemirror@0.1.5": "patches/@handlewithcare%2Fremark-prosemirror@0.1.5.patch",
    "y-prosemirror@1.3.7": "patches/y-prosemirror@1.3.7.patch",
    "@tiptap/y-tiptap@3.0.3": "patches/@tiptap%2Fy-tiptap@3.0.3.patch"
  }
}
