{
  "name": "open-knowledge",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11"
  },
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "cd docs && bun run typecheck",
    "check": "bun run typecheck && bun run lint",
    "prepare": "husky && chmod +x .husky/pre-commit .husky/pre-push 2>/dev/null || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "build-registry": "bun run --cwd packages/core build-registry",
    "drift-check": "bun run build-registry && biome check --write packages/core/src/generated/components.ts && git diff --exit-code packages/core/src/generated/components.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.29.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
