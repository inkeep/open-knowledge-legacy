{
  "name": "@inkeep/open-knowledge",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "open-knowledge": "./dist/cli.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkeep/open-knowledge.git",
    "directory": "packages/cli"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:cli": "tsdown",
    "build:assets": "cp -r ../app/dist dist/public",
    "build": "bun run build:cli && bun run build:assets",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run test"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@inquirer/password": "^5.0.11",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@napi-rs/keyring": "^1.2.0",
    "@octokit/auth-oauth-device": "^8.0.3",
    "@octokit/rest": "^22.0.1",
    "@octokit/request": "^10.0.8",
    "cli-boxes": "^4.0.1",
    "commander": "^14.0.0",
    "just-bash": "^2.14.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "shell-quote": "^1.8.3",
    "smol-toml": "^1.6.1",
    "simple-git": "^3.35.2",
    "sirv": "^3.0.1",
    "ws": "^8.20.0",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@parcel/watcher": "^2.5.6"
  },
  "devDependencies": {
    "@inkeep/open-knowledge-core": "workspace:*",
    "@inkeep/open-knowledge-server": "workspace:*",
    "@types/node": "^22.16.0",
    "@types/picomatch": "^4.0.3",
    "@types/shell-quote": "^1.7.5",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
