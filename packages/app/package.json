{
  "name": "open-knowledge-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test src/",
    "check": "tsc --noEmit && biome check . && bun run test && bun run test:integration && bun run test:conversion",
    "test:integration": "bun test tests/integration/bridge-matrix.test.ts tests/integration/slash-command-extension.test.ts tests/integration/provider-pool-reconnect.test.ts",
    "test:conversion": "bun test tests/integration/conversion-fidelity.test.ts",
    "test:stress:s1-s8-s9": "bun test tests/stress/observers.stress.s1-s8-s9.test.ts",
    "test:stress:s2": "bun test tests/stress/observers.stress.s2.test.ts",
    "test:stress:s4": "bun test tests/stress/observers.stress.s4.test.ts",
    "test:stress:s5-s6": "bun test tests/stress/observers.stress.s5-s6.test.ts",
    "test:fidelity": "bun test --timeout 120000 tests/fidelity/",
    "test:fuzz": "bun test tests/stress/observers.fuzz.test.ts",
    "test:stress:api": "bun run tests/stress/stress-api.ts",
    "test:e2e": "VITE_PORT=13579 playwright test tests/stress/ux-interactions.e2e.ts && VITE_PORT=13579 playwright test tests/stress/crdt-stress.e2e.ts && VITE_PORT=13579 playwright test tests/stress/slash-command.e2e.ts && VITE_PORT=13579 playwright test tests/stress/paste-fidelity.e2e.ts"
  },
