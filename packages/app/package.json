{
  "name": "open-knowledge-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test src/",
    "check": "tsc --noEmit && biome check . && bun run test && bun run test:integration && bun run test:conversion",
    "test:integration": "bun test tests/integration/",
    "test:conversion": "bun test tests/conversion/",
    "test:stress:server-authoritative": "bun test tests/stress/server-authoritative-stress.test.ts",
    "test:fidelity": "bun test --timeout 120000 tests/fidelity/",
    "test:fuzz:bridge": "bun test tests/stress/bridge-convergence.fuzz.test.ts",
    "test:stress:api": "bun run tests/stress/stress-api.ts",
    "test:e2e": "VITE_PORT=13579 playwright test tests/stress/ux-interactions.e2e.ts tests/stress/crdt-stress.e2e.ts tests/stress/slash-command.e2e.ts tests/stress/paste-fidelity.e2e.ts tests/stress/fr-7a-disconnect-source-mode.e2e.ts tests/stress/docs-open.e2e.ts",
    "test:e2e:install-browsers": "playwright install chromium webkit firefox",
    "size": "bun run build && size-limit"
  },
  "size-limit": [
    {
      "name": "main app bundle (gzipped)",
      "path": "dist/assets/index-*.js",
      "limit": "800 kB",
      "gzip": true
    },
    {
      "name": "all JS chunks combined (gzipped)",
      "path": "dist/assets/*.js",
      "limit": "950 kB",
      "gzip": true
    },
    {
      "name": "main CSS (gzipped)",
      "path": "dist/assets/index-*.css",
      "limit": "25 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.1.7",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.1",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hocuspocus/provider": "4.0.0-rc.1",
    "@inkeep/open-knowledge-core": "workspace:*",
    "@inkeep/open-knowledge-server": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/extension-collaboration-cursor": "3.0.0",
    "@tiptap/extension-drag-handle": "3.22.3",
    "@tiptap/extension-file-handler": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/suggestion": "^3.22.3",
    "@tiptap/y-tiptap": "^3.0.3",
    "@uiw/codemirror-theme-basic": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "diff-match-patch": "^1.0.5",
    "fuzzysort": "^3.1.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-resizable-panels": "^4.9.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar": "^4.0.2",
