{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "root": false,
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "error"
      },
      "style": {
        "useImportType": "error"
      }
    }
  },
  "css": {
    "parser": { "cssModules": false },
    "linter": { "enabled": false },
    "formatter": { "enabled": false }
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!**/dist", "!**/*.css"]
  }
}
