{
  "name": "open-knowledge-editor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test",
    "check:fast": "tsc --noEmit && biome check .",
    "check": "tsc --noEmit && biome check . && bun test && vite build"
  },
  "dependencies": {
    "@hocuspocus/provider": "4.0.0-rc.1",
    "@hocuspocus/server": "4.0.0-rc.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/y-tiptap": "^3.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "ws": "^8.20.0",
    "y-codemirror.next": "^0.3.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "codemirror": "^6.0.2",
    "@parcel/watcher": "^2.5.6",
    "diff": "^7.0.0",
    "simple-git": "^3.35.2",
    "yjs": "^13.6.30"
  },
  "overrides": {
    "@codemirror/state": "$@codemirror/state",
    "@codemirror/view": "$@codemirror/view"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
