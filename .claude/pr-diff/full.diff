+      t3.applyDelta([{ insert: 'Paragraph C — agent added this' }]);
+      p3.insert(0, [t3]);
+      frag.push([p3]);
+    });
+
+    // Step 6: Toggle back with three-way merge
+    const result = threeWayMerge(
+      getDoc(conn),
