{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "test:integration": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/integration/bridge-matrix.test.ts",
        "tests/integration/slash-command-extension.test.ts",
        "tests/integration/provider-pool-reconnect.test.ts",
        "tests/integration/test-harness.ts",
        "../server/src/**/*.ts",
        "../core/src/**/*.ts"
      ]
    },
    "test:conversion": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/integration/conversion-fidelity.test.ts",
        "tests/integration/test-harness.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:stress:s1-s8-s9": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/observers.stress.s1-s8-s9.test.ts",
        "tests/stress/synthetic.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:stress:s2": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/observers.stress.s2.test.ts",
        "tests/stress/synthetic.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:stress:s4": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/observers.stress.s4.test.ts",
        "tests/stress/synthetic.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:stress:s5-s6": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/observers.stress.s5-s6.test.ts",
        "tests/stress/synthetic.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:fuzz": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/observers.fuzz.test.ts",
        "tests/stress/synthetic.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:fidelity": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "tests/fidelity/**/*.ts",
        "tests/fidelity/**/*.json",
        "src/editor/**/*.ts",
        "../core/src/**/*.ts",
        "../../patches/@handlewithcare%2Fremark-prosemirror@0.1.5.patch"
      ]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:visual": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:perf": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/component-blocks.perf.test.ts",
        "../core/src/**/*.ts"
      ]
    },
    "test:a11y": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
