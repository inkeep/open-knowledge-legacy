{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "test:integration": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/integration/**/*.ts",
        "../server/src/**/*.ts",
        "../core/src/**/*.ts"
      ]
    },
    "test:conversion": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/integration/conversion-fidelity.test.ts",
        "tests/integration/test-harness.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:stress:server-authoritative": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/server-authoritative-stress.test.ts",
        "tests/integration/test-harness.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:fuzz:bridge": {
      "dependsOn": [],
      "cache": false,
      "inputs": [
        "src/editor/**/*.ts",
        "src/editor/**/*.tsx",
        "tests/stress/bridge-convergence.fuzz.test.ts",
        "tests/integration/test-harness.ts",
        "tests/integration/network-control.ts",
        "../core/src/**/*.ts",
        "../server/src/**/*.ts"
      ]
    },
    "test:fidelity": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "tests/fidelity/**/*.ts",
        "tests/fidelity/**/*.json",
        "src/editor/**/*.ts",
        "../core/src/**/*.ts",
        "../../patches/@handlewithcare%2Fremark-prosemirror@0.1.5.patch"
      ]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:perf:bench": {
      "dependsOn": [],
      "cache": false,
      "inputs": [
        "src/markdown/**/*.ts",
        "src/markdown/fixtures/perf/*.md",
        "tests/perf/markdown-bench.test.ts"
      ],
      "env": ["RUN_BENCH", "BENCH_RUNNER_CLASS"]
    },
    "test:perf:fallback": {
      "dependsOn": [],
      "cache": false,
      "inputs": [
        "src/markdown/**/*.ts",
        "src/markdown/fixtures/perf/*.md",
        "src/markdown/parse-with-fallback.test.ts"
      ],
      "env": ["RUN_BENCH"]
    },
    "test:perf:regression:unit": {
      "dependsOn": [],
      "cache": true,
      "inputs": ["tests/perf/regression-gate.ts", "tests/perf/regression-gate.test.ts"]
    },
    "test:perf:regression": {
      "dependsOn": [],
      "cache": false,
      "inputs": [
        "src/markdown/**/*.ts",
        "src/markdown/fixtures/perf/*.md",
        "tests/perf/markdown-bench.test.ts",
        "tests/perf/regression-gate.ts",
        "tests/perf/run-regression-gate.ts",
        "tests/perf/baseline.json"
      ],
      "env": ["RUN_BENCH", "BENCH_RUNNER_CLASS"]
    },
    "test:health:unit": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/metrics/parse-health.ts",
        "src/markdown/**/*.ts",
        "tests/health/parse-health-gate.ts",
        "tests/health/parse-health-gate.test.ts"
      ]
    },
    "test:health": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "src/metrics/parse-health.ts",
        "src/markdown/**/*.ts",
        "src/markdown/fixtures/**",
        "tests/health/parse-health-gate.ts",
        "tests/health/baseline.json"
      ]
    }
  }
}
